# Variables de entorno para el contenedor de PHP
PHP_MEMORY_LIMIT=2G
PHP_MAX_EXECUTION_TIME=1800
PHP_ZLIB_OUTPUT_COMPRESSION=On
PHP_CGI_FIX_PATHINFO=0
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_POST_MAX_SIZE=100M
PHP_MAX_INPUT_VARS=10000

# Variables de entorno para la base de datos
DB_HOST=db
DB_PORT=3306
DB_NAME=magento
DB_USER=magento
DB_PASSWORD=your_db_password_here

# Variables de entorno para Magento
MAGENTO_MODE=production
MAGENTO_BACKEND_FRONTNAME=admin

# Variables de entorno para Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Variables de entorno para Elasticsearch
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_es_password_here